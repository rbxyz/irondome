{
  "name": "irondome",
  "version": "0.0.4",
  "description": "CLI to scaffold Irondome (PBAC/ReBAC) in Next.js projects",
  "license": "MIT",
  "type": "module",
  "bin": "./dist/index.js",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nextjs",
    "pbac",
    "rebac",
    "authorization",
    "permissions",
    "cli"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
