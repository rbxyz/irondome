{
  "name": "@irondome/next",
  "version": "0.1.3",
  "description": "Next.js App Router helpers for Irondome permissions",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nextjs",
    "middleware",
    "trpc",
    "authorization",
    "irondome"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@irondome/auth": ">=0.1.0",
    "@irondome/core": ">=0.1.0",
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@irondome/auth": "workspace:*",
    "@irondome/core": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "19.2.2",
    "eslint": "^9.39.1",
    "next": "16.2.0",
    "react": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}
