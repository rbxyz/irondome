{
  "name": "@irondome/auth",
  "version": "0.1.2",
  "description": "Authentication + Session adapters for Irondome",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./jwt": {
      "import": {
        "types": "./dist/jwt.d.ts",
        "default": "./dist/jwt.js"
      },
      "require": {
        "types": "./dist/jwt.d.ts",
        "default": "./dist/jwt.cjs"
      }
    },
    "./schema/pg": {
      "import": {
        "types": "./dist/schema/pg.d.ts",
        "default": "./dist/schema/pg.js"
      },
      "require": {
        "types": "./dist/schema/pg.d.ts",
        "default": "./dist/schema/pg.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jose": "^5.10.0"
  },
  "peerDependencies": {
    "@irondome/core": ">=0.1.0",
    "drizzle-orm": ">=0.36.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@irondome/core": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "drizzle-orm": "^0.43.1",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}
